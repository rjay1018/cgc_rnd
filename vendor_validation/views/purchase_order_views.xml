<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add a domain to the purchase order form -->
    <record id="view_purchase_order_form_inherit_validation" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.validation</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="domain">[('is_vendor_validated', '=', True), '|', ('company_id', '=', False), ('company_id', '=', company_id)]</attribute>
            </xpath>
        </field>
    </record>
</odoo>
