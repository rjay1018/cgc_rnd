<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_vendor_validation" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.vendor.validation</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Validation &amp; Compliance" name="vendor_validation" invisible="supplier_rank == 0 or not is_company">
                    <field name="trigger_auto_load_requirements" invisible="1"/>
                    <group>
                        <group>
                            <field name="validation_status" widget="badge"
                                decoration-success="validation_status == 'validated'"
                                decoration-warning="validation_status == 'in_progress'"
                                decoration-danger="validation_status == 'not_valid'"
                                readonly="1"/>
                        </group>
                    </group>
                    <field name="validation_document_ids">
                        <list editable="bottom" create="false" delete="false">
                            <field name="requirement_type_id" readonly="1"/>
                            <field name="file_upload" widget="binary" filename="file_name" invisible="status == 'uploaded'"/>
                            <field name="file_name" invisible="1"/>
                            <field name="document_id" widget="many2one" readonly="1" invisible="status == 'missing'"/>
                            <field name="upload_date" readonly="1"/>
                            <field name="status" widget="badge" decoration-success="status == 'uploaded'" decoration-warning="status == 'missing'" decoration-danger="status == 'expired'" readonly="1"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Predefined Filter for Search Views as referenced in Odoo Docs -->
    <record id="view_res_partner_filter_inherit_vendor_validation" model="ir.ui.view">
        <field name="name">res.partner.select.inherit.vendor.validation</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_res_partner_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='supplier']" position="after">
                <filter string="Validated Vendors" name="filter_validated_vendors" domain="[('validation_status', '=', 'validated')]"/>
                <filter string="In-Progress Vendors" name="filter_inprogress_vendors" domain="[('validation_status', '=', 'in_progress')]"/>
                <filter string="Not Valid Vendors" name="filter_notvalid_vendors" domain="[('validation_status', '=', 'not_valid')]"/>
            </xpath>
        </field>
    </record>

    <!-- Add validation_status badge tag to the partner list view -->
    <record id="view_partner_list_inherit_vendor_validation" model="ir.ui.view">
        <field name="name">res.partner.list.inherit.vendor.validation</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <field name="validation_status" widget="badge" optional="show"
                    decoration-success="validation_status == 'validated'"
                    decoration-warning="validation_status == 'in_progress'"
                    decoration-danger="validation_status == 'not_valid'"
                    readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
