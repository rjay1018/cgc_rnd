<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_vendor_validation" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.vendor.validation</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Validation &amp; Compliance" name="vendor_validation" invisible="supplier_rank == 0 or not is_company">
                    <group>
                        <group>
                            <field name="validation_progress" widget="progressbar"/>
                            <field name="is_vendor_validated" readonly="1" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <field name="validation_document_ids">
                        <list editable="bottom">
                            <field name="requirement_type_id"/>
                            <field name="document_id" widget="many2one_avatar"/>
                            <field name="upload_date"/>
                            <field name="status" widget="badge" decoration-success="status == 'uploaded'" decoration-danger="status == 'expired'"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
