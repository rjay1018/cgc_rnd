<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_supplierinfo_form_view_inherit_validation" model="ir.ui.view">
        <field name="name">product.supplierinfo.form.view.inherit.validation</field>
        <field name="model">product.supplierinfo</field>
        <field name="inherit_id" ref="product.product_supplierinfo_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="domain">[('validation_progress', '=', 100)]</attribute>
            </xpath>
        </field>
    </record>
</odoo>
